{"config":{"lang":["ja"],"separator":"[\\s\\-\u3000\u3001\u3002\uff0c\uff0e]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"My Blog","text":"<p>AI\u652f\u63f4\u3067\u904b\u55b6\u3059\u308b\u30d6\u30ed\u30b0\u3067\u3059\u3002</p>"},{"location":"about/","title":"About","text":"<p>\u3053\u306e\u30b5\u30a4\u30c8\u306b\u3064\u3044\u3066\u3002</p>"},{"location":"privacy/","title":"Privacy Policy","text":"<p>\u3053\u306e\u30b5\u30a4\u30c8\u306e\u30d7\u30e9\u30a4\u30d0\u30b7\u30fc\u30dd\u30ea\u30b7\u30fc\u3067\u3059\u3002</p>"},{"location":"blog/","title":"Blog","text":""},{"location":"blog/2026/05/18/ai-blog-workflow/","title":"AI\u3092\u4f7f\u3063\u3066\u30d6\u30ed\u30b0\u8a18\u4e8b\u3092\u66f8\u304f\u3068\u304d\u306e\u5b89\u5168\u306a\u30ef\u30fc\u30af\u30d5\u30ed\u30fc","text":"","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_1","title":"\u6982\u8981","text":"<p>AI\u3092\u4f7f\u3046\u3068\u3001\u30d6\u30ed\u30b0\u8a18\u4e8b\u306e\u30c6\u30fc\u30de\u6574\u7406\u3084\u4e0b\u66f8\u304d\u4f5c\u6210\u3092\u52b9\u7387\u5316\u3067\u304d\u307e\u3059\u3002\u4e00\u65b9\u3067\u3001AI\u306e\u51fa\u529b\u306b\u306f\u8aa4\u3063\u305f\u60c5\u5831\u3001\u5b58\u5728\u3057\u306a\u3044\u51fa\u5178\u3001\u78ba\u8a8d\u304c\u5fc5\u8981\u306a\u5185\u5bb9\u304c\u542b\u307e\u308c\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002</p> <p>\u3053\u306e\u8a18\u4e8b\u3067\u306f\u3001AI\u3067\u8a18\u4e8b\u3092\u66f8\u304f\u3068\u304d\u306b\u3001\u8abf\u67fb\u30e1\u30e2\u3001\u4e0b\u66f8\u304d\u3001\u516c\u958b\u7528\u306e\u8a18\u4e8b\u3092\u5206\u3051\u3066\u7ba1\u7406\u3059\u308b\u8003\u3048\u65b9\u3092\u307e\u3068\u3081\u307e\u3059\u3002\u524d\u63d0\u306f\u3001AI\u306e\u51fa\u529b\u3092\u305d\u306e\u307e\u307e\u516c\u958b\u3059\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u4eba\u9593\u304c\u5185\u5bb9\u3092\u78ba\u8a8d\u3057\u3066\u304b\u3089\u516c\u958b\u3059\u308b\u904b\u7528\u3067\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_2","title":"\u672c\u6587","text":"","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#ai_1","title":"AI\u306e\u51fa\u529b\u306f\u78ba\u8a8d\u3092\u524d\u63d0\u306b\u6271\u3046","text":"<p>AI\u306f\u6587\u7ae0\u4f5c\u6210\u306e\u52a9\u3051\u306b\u306a\u308a\u307e\u3059\u304c\u3001\u51fa\u529b\u304c\u5e38\u306b\u6b63\u3057\u3044\u3068\u306f\u9650\u308a\u307e\u305b\u3093\u3002OpenAI\u306f\u3001ChatGPT\u306a\u3069\u306e\u8a00\u8a9e\u30e2\u30c7\u30eb\u304c\u8aa4\u3063\u305f\u60c5\u5831\u3084\u8aa4\u89e3\u3092\u62db\u304f\u5185\u5bb9\u3092\u751f\u6210\u3059\u308b\u5834\u5408\u304c\u3042\u308a\u3001\u5b58\u5728\u3057\u306a\u3044\u5f15\u7528\u3084\u51fa\u5178\u3092\u793a\u3059\u3053\u3068\u3082\u3042\u308b\u3068\u8aac\u660e\u3057\u3066\u3044\u307e\u3059\u3002</p> <p>\u305d\u306e\u305f\u3081\u3001AI\u3092\u4f7f\u3063\u3066\u8a18\u4e8b\u3092\u4f5c\u308b\u3068\u304d\u306f\u3001\u51fa\u529b\u3055\u308c\u305f\u6587\u7ae0\u3092\u305d\u306e\u307e\u307e\u516c\u958b\u3059\u308b\u306e\u3067\u306f\u306a\u304f\u3001\u91cd\u8981\u306a\u60c5\u5831\u3092\u4fe1\u983c\u3067\u304d\u308b\u60c5\u5831\u6e90\u3067\u78ba\u8a8d\u3059\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u3002\u7279\u306b\u3001\u51fa\u5178\u3001\u65e5\u4ed8\u3001\u4ed5\u69d8\u3001\u5236\u5ea6\u3001\u516c\u958b\u7bc4\u56f2\u306a\u3069\u3001\u5909\u308f\u308b\u53ef\u80fd\u6027\u304c\u3042\u308b\u60c5\u5831\u306f\u6ce8\u610f\u3057\u3066\u6271\u3044\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_3","title":"\u8abf\u67fb\u30e1\u30e2\u3001\u4e0b\u66f8\u304d\u3001\u516c\u958b\u8a18\u4e8b\u3092\u5206\u3051\u308b","text":"<p>\u672a\u78ba\u8a8d\u60c5\u5831\u306e\u6df7\u5165\u3092\u6e1b\u3089\u3059\u306b\u306f\u3001\u4f5c\u696d\u4e2d\u306e\u60c5\u5831\u3068\u516c\u958b\u7528\u306e\u60c5\u5831\u3092\u5206\u3051\u3066\u304a\u304f\u3053\u3068\u304c\u91cd\u8981\u3067\u3059\u3002</p> <p>\u3053\u306e\u30d6\u30ed\u30b0\u306e\u904b\u7528\u3067\u306f\u3001\u4e3b\u306b\u6b21\u306e\u5834\u6240\u3092\u4f7f\u3044\u5206\u3051\u307e\u3059\u3002</p> <ul> <li><code>research/</code>\uff1a\u8abf\u67fb\u30e1\u30e2\u3001\u51fa\u5178\u3001\u78ba\u8a8d\u65e5\u3001\u672a\u78ba\u8a8d\u4e8b\u9805\u3092\u6b8b\u3059\u5834\u6240</li> <li><code>drafts/</code>\uff1aAI\u751f\u6210\u6587\u3084\u7de8\u96c6\u4e2d\u306e\u4e0b\u66f8\u304d\u3092\u7f6e\u304f\u5834\u6240</li> <li><code>docs/</code>\uff1a\u516c\u958b\u3067\u304d\u308b\u5185\u5bb9\u3060\u3051\u3092\u7f6e\u304f\u5834\u6240</li> <li><code>docs/blog/posts/</code>\uff1a\u6700\u7d42\u7684\u306b\u516c\u958b\u3059\u308b\u30d6\u30ed\u30b0\u8a18\u4e8b\u3060\u3051\u3092\u7f6e\u304f\u5834\u6240</li> </ul> <p>\u8a18\u4e8b\u306e\u4e8b\u5b9f\u95a2\u4fc2\u306f\u3001<code>research/</code> \u306b\u3042\u308b\u8abf\u67fb\u30e1\u30e2\u3092\u6839\u62e0\u306b\u3057\u307e\u3059\u3002\u4e0b\u66f8\u304d\u3092\u4f5c\u308b\u3068\u304d\u3082\u3001<code>research/</code> \u306b\u306a\u3044\u4e8b\u5b9f\u306f\u8ffd\u52a0\u3057\u307e\u305b\u3093\u3002AI\u304c\u81ea\u7136\u306a\u6587\u7ae0\u3092\u51fa\u3057\u3066\u3044\u3066\u3082\u3001\u6839\u62e0\u304c\u78ba\u8a8d\u3067\u304d\u306a\u3044\u5185\u5bb9\u306f\u672c\u6587\u306b\u6df7\u305c\u305a\u3001\u78ba\u8a8d\u304c\u5fc5\u8981\u306a\u9805\u76ee\u3068\u3057\u3066\u5206\u3051\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#research","title":"<code>research/</code> \u306b\u306f\u6839\u62e0\u3092\u6b8b\u3059","text":"<p><code>research/</code> \u306b\u306f\u3001\u8a18\u4e8b\u672c\u6587\u306e\u6750\u6599\u306b\u306a\u308b\u60c5\u5831\u3092\u6574\u7406\u3057\u307e\u3059\u3002\u51fa\u5178URL\u3001\u78ba\u8a8d\u65e5\u3001\u8981\u70b9\u3001\u672a\u78ba\u8a8d\u4e8b\u9805\u3092\u5206\u3051\u3066\u6b8b\u3057\u3066\u304a\u304f\u3068\u3001\u3042\u3068\u304b\u3089\u300c\u3053\u306e\u8a18\u8ff0\u306f\u4f55\u3092\u6839\u62e0\u306b\u3057\u3066\u3044\u308b\u306e\u304b\u300d\u3092\u78ba\u8a8d\u3057\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002</p> <p>AI\u306e\u51fa\u529b\u3092\u8abf\u67fb\u30e1\u30e2\u306b\u4f7f\u3046\u5834\u5408\u3067\u3082\u3001\u51fa\u529b\u5185\u5bb9\u3060\u3051\u3092\u6839\u62e0\u306b\u306f\u3057\u307e\u305b\u3093\u3002\u516c\u5f0f\u60c5\u5831\u3084\u4e00\u6b21\u60c5\u5831\u3092\u78ba\u8a8d\u3057\u3001\u78ba\u8a8d\u3067\u304d\u305f\u5185\u5bb9\u3068\u78ba\u8a8d\u3067\u304d\u3066\u3044\u306a\u3044\u5185\u5bb9\u3092\u5206\u3051\u307e\u3059\u3002</p> <p>NIST\u306e\u751f\u6210AI\u5411\u3051\u30ea\u30b9\u30af\u7ba1\u7406\u30d5\u30ec\u30fc\u30e0\u30ef\u30fc\u30af\u30fb\u30d7\u30ed\u30d5\u30a1\u30a4\u30eb\u3067\u306f\u3001\u751f\u6210AI\u304c\u51fa\u529b\u3057\u305f\u60c5\u5831\u306e\u6b63\u78ba\u6027\u3084\u771f\u5b9f\u6027\u3092\u78ba\u8a8d\u3059\u308b\u305f\u3081\u306e\u30d5\u30a1\u30af\u30c8\u30c1\u30a7\u30c3\u30af\u3001\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u6765\u6b74\u3084\u5909\u66f4\u5c65\u6b74\u306e\u7ba1\u7406\u3001\u4eba\u9593\u306b\u3088\u308b\u30ec\u30d3\u30e5\u30fc\u3084\u30e2\u30c7\u30ec\u30fc\u30b7\u30e7\u30f3\u304c\u793a\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u30d6\u30ed\u30b0\u8a18\u4e8b\u306e\u904b\u7528\u306b\u7f6e\u304d\u63db\u3048\u308b\u3068\u3001\u51fa\u5178\u3084\u78ba\u8a8d\u7d50\u679c\u3092\u6b8b\u3059\u3053\u3068\u306f\u3001\u516c\u958b\u524d\u306b\u78ba\u8a8d\u3059\u3079\u304d\u5185\u5bb9\u3092\u6574\u7406\u3059\u308b\u52a9\u3051\u306b\u306a\u308a\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#drafts","title":"<code>drafts/</code> \u306f\u516c\u958b\u524d\u306e\u4f5c\u696d\u5834\u6240\u306b\u3059\u308b","text":"<p><code>drafts/</code> \u306f\u3001AI\u751f\u6210\u6587\u3084\u7de8\u96c6\u4e2d\u306e\u6587\u7ae0\u3092\u7f6e\u304f\u5834\u6240\u3067\u3059\u3002\u3053\u3053\u306b\u3042\u308b\u6587\u7ae0\u306f\u3001\u516c\u958b\u524d\u306e\u78ba\u8a8d\u30fb\u7de8\u96c6\u3092\u524d\u63d0\u306b\u3057\u305f\u3082\u306e\u3067\u3059\u3002</p> <p>\u4e0b\u66f8\u304d\u3067\u306f\u3001\u6587\u7ae0\u306e\u6d41\u308c\u3084\u8aad\u307f\u3084\u3059\u3055\u3092\u6574\u3048\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u8aad\u307f\u3084\u3059\u304f\u3059\u308b\u305f\u3081\u306b\u3001\u8abf\u67fb\u30e1\u30e2\u306b\u306a\u3044\u4e8b\u5b9f\u3092\u8db3\u3057\u3066\u306f\u3044\u3051\u307e\u305b\u3093\u3002\u672a\u78ba\u8a8d\u306e\u5185\u5bb9\u3001\u63a8\u6e2c\u3001\u5909\u52d5\u3057\u3084\u3059\u3044\u60c5\u5831\u306f\u3001\u672c\u6587\u306b\u6df7\u305c\u305a\u306b\u300c\u8981\u78ba\u8a8d\u300d\u3068\u3057\u3066\u5206\u3051\u307e\u3059\u3002</p> <p>\u3053\u306e\u6bb5\u968e\u3067\u5927\u5207\u306a\u306e\u306f\u3001\u8a18\u4e8b\u3089\u3057\u3044\u6587\u7ae0\u306b\u3059\u308b\u3053\u3068\u3068\u3001\u78ba\u8a8d\u3067\u304d\u3066\u3044\u306a\u3044\u60c5\u5831\u3092\u516c\u958b\u7528\u672c\u6587\u306b\u6df7\u305c\u306a\u3044\u3053\u3068\u3092\u4e21\u7acb\u3059\u308b\u3053\u3068\u3067\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#docs","title":"<code>docs/</code> \u306b\u306f\u516c\u958b\u3067\u304d\u308b\u5185\u5bb9\u3060\u3051\u3092\u7f6e\u304f","text":"<p>MkDocs\u3067\u306f\u3001<code>mkdocs.yml</code> \u3068 <code>docs/</code> \u30d5\u30a9\u30eb\u30c0\u304c\u57fa\u672c\u69cb\u6210\u3068\u3057\u3066\u4f7f\u308f\u308c\u307e\u3059\u3002MkDocs\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3067\u306f\u3001<code>docs/</code> \u304c\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u306e\u65e2\u5b9a\u5024\u3067\u3042\u308a\u3001<code>docs/</code> \u914d\u4e0b\u306eMarkdown\u30d5\u30a1\u30a4\u30eb\u304b\u3089\u30da\u30fc\u30b8\u304c\u751f\u6210\u3055\u308c\u308b\u3068\u8aac\u660e\u3055\u308c\u3066\u3044\u307e\u3059\u3002</p> <p>\u307e\u305f\u3001MkDocs\u306e\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u3067\u306f\u3001\u30ca\u30d3\u30b2\u30fc\u30b7\u30e7\u30f3\u306b\u542b\u3081\u3066\u3044\u306a\u3044\u30da\u30fc\u30b8\u3067\u3082\u3001\u30d3\u30eb\u30c9\u3055\u308c\u305f\u30b5\u30a4\u30c8\u306b\u542b\u307e\u308c\u3001\u76f4\u63a5\u30ea\u30f3\u30af\u3055\u308c\u308b\u53ef\u80fd\u6027\u304c\u3042\u308b\u3068\u8aac\u660e\u3055\u308c\u3066\u3044\u307e\u3059\u3002Markdown\u4ee5\u5916\u306e\u30d5\u30a1\u30a4\u30eb\u3082\u3001\u30c9\u30ad\u30e5\u30e1\u30f3\u30c8\u30c7\u30a3\u30ec\u30af\u30c8\u30ea\u5185\u306b\u3042\u308b\u5834\u5408\u306f\u30d3\u30eb\u30c9\u5f8c\u306e\u30b5\u30a4\u30c8\u3078\u30b3\u30d4\u30fc\u3055\u308c\u308b\u3068\u3055\u308c\u3066\u3044\u307e\u3059\u3002</p> <p>GitHub Docs\u3067\u306f\u3001GitHub Pages\u306e\u30b5\u30a4\u30c8\u306f\u30a4\u30f3\u30bf\u30fc\u30cd\u30c3\u30c8\u4e0a\u3067\u516c\u958b\u3055\u308c\u3001\u30ea\u30dd\u30b8\u30c8\u30ea\u304c\u975e\u516c\u958b\u3067\u3042\u3063\u3066\u3082Pages\u30b5\u30a4\u30c8\u81ea\u4f53\u306f\u516c\u958b\u3055\u308c\u5f97\u308b\u3068\u8aac\u660e\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u305d\u306e\u305f\u3081\u3001\u6a5f\u5bc6\u60c5\u5831\u304c\u3042\u308b\u5834\u5408\u306f\u516c\u958b\u524d\u306b\u53d6\u308a\u9664\u304f\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u3002</p> <p>\u305d\u306e\u305f\u3081\u3001<code>docs/</code> \u306b\u306f\u516c\u958b\u3067\u304d\u308b\u5185\u5bb9\u3060\u3051\u3092\u7f6e\u304f\u904b\u7528\u306b\u3057\u307e\u3059\u3002\u4e0b\u66f8\u304d\u3001\u8abf\u67fb\u30e1\u30e2\u3001\u5185\u90e8\u30e1\u30e2\u3001\u672a\u78ba\u8a8d\u60c5\u5831\u306f <code>docs/</code> \u306b\u7f6e\u304b\u305a\u3001<code>research/</code> \u3084 <code>drafts/</code> \u306b\u5206\u3051\u3066\u7ba1\u7406\u3057\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#ai_2","title":"AI\u751f\u6210\u30b3\u30f3\u30c6\u30f3\u30c4\u306f\u8aad\u8005\u306b\u5f79\u7acb\u3064\u5185\u5bb9\u306b\u3059\u308b","text":"<p>Google Search Central\u306f\u3001AI\u751f\u6210\u304b\u3069\u3046\u304b\u3067\u306f\u306a\u304f\u3001\u72ec\u81ea\u6027\u304c\u3042\u308a\u9ad8\u54c1\u8cea\u3067\u4eba\u306e\u5f79\u306b\u7acb\u3064\u30b3\u30f3\u30c6\u30f3\u30c4\u304b\u3069\u3046\u304b\u3092\u91cd\u8996\u3059\u308b\u3068\u8aac\u660e\u3057\u3066\u3044\u307e\u3059\u3002\u4e00\u65b9\u3067\u3001\u691c\u7d22\u9806\u4f4d\u306e\u64cd\u4f5c\u3092\u4e3b\u76ee\u7684\u3068\u3059\u308b\u81ea\u52d5\u751f\u6210\u30b3\u30f3\u30c6\u30f3\u30c4\u306f\u3001\u30b9\u30d1\u30e0\u30dd\u30ea\u30b7\u30fc\u9055\u53cd\u306b\u306a\u308a\u5f97\u307e\u3059\u3002</p> <p>\u3064\u307e\u308a\u3001AI\u3092\u4f7f\u3046\u3053\u3068\u81ea\u4f53\u3088\u308a\u3082\u3001\u8aad\u8005\u306b\u5f79\u7acb\u3064\u5185\u5bb9\u306b\u306a\u3063\u3066\u3044\u308b\u304b\u3001\u4fe1\u983c\u3067\u304d\u308b\u60c5\u5831\u306b\u57fa\u3065\u3044\u3066\u3044\u308b\u304b\u3001\u516c\u958b\u524d\u306b\u78ba\u8a8d\u3055\u308c\u3066\u3044\u308b\u304b\u304c\u91cd\u8981\u3067\u3059\u3002</p> <p>AI\u306f\u3001\u30c6\u30fc\u30de\u6574\u7406\u3084\u4e0b\u66f8\u304d\u4f5c\u6210\u306b\u306f\u4f7f\u3048\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u6700\u7d42\u7684\u306b\u306f\u4eba\u9593\u304c\u3001\u4e8b\u5b9f\u95a2\u4fc2\u3001\u51fa\u5178\u3001\u8868\u73fe\u3001\u516c\u958b\u3057\u3066\u3088\u3044\u5185\u5bb9\u304b\u3069\u3046\u304b\u3092\u78ba\u8a8d\u3057\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_4","title":"\u5b89\u5168\u306a\u8a18\u4e8b\u4f5c\u6210\u30d5\u30ed\u30fc\u306e\u8003\u3048\u65b9","text":"<p>AI\u3092\u4f7f\u3063\u305f\u8a18\u4e8b\u4f5c\u6210\u3067\u306f\u3001\u6b21\u306e\u3088\u3046\u306a\u6d41\u308c\u306b\u3059\u308b\u3068\u3001\u78ba\u8a8d\u3059\u3079\u304d\u5185\u5bb9\u3092\u8ffd\u3044\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002</p> <ol> <li><code>briefs/</code> \u306b\u8a18\u4e8b\u306e\u76ee\u7684\u3001\u60f3\u5b9a\u8aad\u8005\u3001\u6271\u3046\u7bc4\u56f2\u3092\u6574\u7406\u3059\u308b</li> <li><code>research/</code> \u306b\u51fa\u5178\u3001\u78ba\u8a8d\u65e5\u3001\u8981\u70b9\u3001\u672a\u78ba\u8a8d\u4e8b\u9805\u3092\u8a18\u9332\u3059\u308b</li> <li><code>drafts/</code> \u306b\u8abf\u67fb\u30e1\u30e2\u3092\u6839\u62e0\u306b\u3057\u305f\u4e0b\u66f8\u304d\u3092\u4f5c\u308b</li> <li>\u4e0b\u66f8\u304d\u5185\u306e\u672a\u78ba\u8a8d\u60c5\u5831\u3092\u672c\u6587\u304b\u3089\u5206\u3051\u308b</li> <li>\u4eba\u9593\u304c\u5185\u5bb9\u3001\u51fa\u5178\u3001\u8868\u73fe\u3092\u78ba\u8a8d\u3059\u308b</li> <li>\u516c\u958b\u3067\u304d\u308b\u72b6\u614b\u306b\u306a\u3063\u305f\u8a18\u4e8b\u3060\u3051\u3092 <code>docs/blog/posts/</code> \u306b\u79fb\u3059</li> </ol> <p>\u3053\u306e\u6d41\u308c\u3067\u3082\u3001\u8aa4\u60c5\u5831\u3092\u5b8c\u5168\u306b\u9632\u3052\u308b\u308f\u3051\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u4eba\u9593\u306e\u78ba\u8a8d\u6f0f\u308c\u3084\u3001\u60c5\u5831\u304c\u516c\u958b\u5f8c\u306b\u5909\u308f\u308b\u30ea\u30b9\u30af\u306f\u6b8b\u308a\u307e\u3059\u3002\u305d\u308c\u3067\u3082\u3001\u8abf\u67fb\u30e1\u30e2\u3001\u4e0b\u66f8\u304d\u3001\u516c\u958b\u8a18\u4e8b\u3092\u5206\u3051\u3066\u304a\u304f\u3053\u3068\u3067\u3001\u3069\u306e\u60c5\u5831\u3092\u78ba\u8a8d\u3057\u3001\u3069\u306e\u60c5\u5831\u304c\u672a\u78ba\u8a8d\u306a\u306e\u304b\u3092\u8ffd\u3044\u3084\u3059\u304f\u306a\u308a\u307e\u3059\u3002</p> <p>AI\u3092\u4f7f\u3046\u3053\u3068\u3067\u3001\u30c6\u30fc\u30de\u6574\u7406\u3084\u4e0b\u66f8\u304d\u4f5c\u6210\u3092\u52b9\u7387\u5316\u3067\u304d\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002\u305d\u306e\u5206\u3001\u3069\u3053\u307e\u3067\u78ba\u8a8d\u3067\u304d\u3066\u3044\u308b\u306e\u304b\u3092\u660e\u78ba\u306b\u6b8b\u3059\u3053\u3068\u304c\u5927\u5207\u3067\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_5","title":"\u53c2\u8003\u60c5\u5831","text":"<ul> <li>\u516c\u5f0f\u60c5\u5831\u30fb\u4e00\u6b21\u60c5\u5831:</li> <li><code>AGENTS.md</code></li> <li><code>briefs/2026-05-18-ai-blog-workflow-brief.md</code></li> <li>https://help.openai.com/en/articles/8313428-does-chatgpt-tell-the-truth</li> <li>https://developers.google.com/search/blog/2023/02/google-search-and-ai-content</li> <li>https://nvlpubs.nist.gov/nistpubs/ai/NIST.AI.600-1.pdf</li> <li>https://www.mkdocs.org/getting-started/</li> <li>https://www.mkdocs.org/user-guide/writing-your-docs/</li> <li>https://docs.github.com/en/pages/getting-started-with-github-pages/creating-a-github-pages-site</li> <li>\u88dc\u8db3\u60c5\u5831:</li> <li>\u306a\u3057</li> </ul>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/ai-blog-workflow/#_6","title":"\u8981\u78ba\u8a8d","text":"<ul> <li>MkDocs\u3084Markdown\u30d6\u30ed\u30b0\u306b\u304a\u3044\u3066\u3001<code>research/</code>\u3001<code>drafts/</code>\u3001<code>docs/</code> \u306e\u3088\u3046\u306b\u4f5c\u696d\u9818\u57df\u3092\u660e\u78ba\u306b\u5206\u3051\u308b\u516c\u5f0f\u306e\u63a8\u5968\u30d1\u30bf\u30fc\u30f3\u304c\u5b58\u5728\u3059\u308b\u304b\u306f\u672a\u78ba\u8a8d\u3067\u3059\u3002\u4eca\u56de\u78ba\u8a8d\u3067\u304d\u305f\u306e\u306f\u3001MkDocs\u3067 <code>docs/</code> \u304c\u30b5\u30a4\u30c8\u30bd\u30fc\u30b9\u306b\u306a\u308b\u3068\u3044\u3046\u4ed5\u69d8\u3067\u3059\u3002</li> <li>Google Search Central\u306eAI\u751f\u6210\u30b3\u30f3\u30c6\u30f3\u30c4\u65b9\u91dd\u306f\u78ba\u8a8d\u3057\u307e\u3057\u305f\u304c\u3001\u500b\u5225\u306e\u691c\u7d22\u9806\u4f4d\u3078\u306e\u5f71\u97ff\u3092\u65ad\u5b9a\u3067\u304d\u308b\u60c5\u5831\u306f\u78ba\u8a8d\u3057\u3066\u3044\u307e\u305b\u3093\u3002\u691c\u7d22\u8a55\u4fa1\u3078\u306e\u5177\u4f53\u7684\u306a\u5f71\u97ff\u306f\u8981\u78ba\u8a8d\u3067\u3059\u3002</li> <li>AI\u751f\u6210\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u95a2\u3059\u308b\u6cd5\u7684\u30fb\u8457\u4f5c\u6a29\u4e0a\u306e\u6271\u3044\u306f\u3001\u56fd\u3084\u7528\u9014\u306b\u3088\u3063\u3066\u5909\u308f\u308b\u53ef\u80fd\u6027\u304c\u3042\u308b\u305f\u3081\u3001\u3053\u306e\u8a18\u4e8b\u3067\u306f\u65ad\u5b9a\u3057\u3066\u3044\u307e\u305b\u3093\u3002</li> </ul> <p>\u3053\u306e\u8a18\u4e8b\u306f\u3001AI\u30c4\u30fc\u30eb\u3092\u7528\u3044\u305f\u60c5\u5831\u6574\u7406\u30fb\u4e0b\u66f8\u304d\u4f5c\u6210\u3092\u3082\u3068\u306b\u3001\u30b5\u30a4\u30c8\u904b\u55b6\u8005\u304c\u5185\u5bb9\u78ba\u8a8d\u30fb\u7de8\u96c6\u3092\u884c\u3044\u516c\u958b\u3057\u3066\u3044\u307e\u3059\u3002</p>","tags":["AI","\u30d6\u30ed\u30b0\u904b\u7528","Markdown","MkDocs"]},{"location":"blog/2026/05/18/sample/","title":"\u30b5\u30f3\u30d7\u30eb\u8a18\u4e8b","text":"<p>\u3053\u308c\u306fMkdocs Material\u3067\u4f5c\u6210\u3057\u305f\u30b5\u30f3\u30d7\u30eb\u8a18\u4e8b\u3067\u3059\u3002 \u3053\u306e\u8a18\u4e8b\u306f\u3001AI\u30c4\u30fc\u30eb\u3092\u7528\u3044\u305f\u8abf\u67fb\u30fb\u57f7\u7b46\u306b\u3088\u308a\u3001\u30b5\u30a4\u30c8\u904b\u55b6\u8005\u304c\u7de8\u96c6\u76e3\u7763\u3092\u884c\u3044\u516c\u958b\u3057\u3066\u3044\u307e\u3059\u3002</p>","tags":["MkDocs","GitHub Pages"]},{"location":"blog/archive/2026/","title":"2026","text":""},{"location":"blog/category/blog/","title":"Blog","text":""}]}